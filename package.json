{
  "name": "epi-ad-tracker-v2",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "db:generate": "pnpm --filter @repo/db db:generate",
    "db:push": "pnpm --filter @repo/db db:push",
    "db:studio": "pnpm --filter @repo/db db:studio",
    "dev:web": "pnpm --filter web dev",
    "dev:legacy": "pnpm --filter legacy-web dev",
    "dev": "turbo dev --parallel",
    "lint": "turbo lint",
    "postinstall": "pnpm db:generate && pnpm --filter @repo/ui build",
    "test": "turbo test",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/node": "^22.13.14",
    "eslint": "^8.57.1",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  },
  "packageManager": "pnpm@10.6.2"
}
